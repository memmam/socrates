//? expect: header: [66, 76, 77, 49, 6, 0, 0, 16, 0, 0, 244, 1, 0, 0]
//? expect: committed filter.bin identical to fresh build: true
//? expect: wrote demos/bloom/filter.bin (526 bytes), read-back identical: true
