// glcube, Vulkan edition — the same spinning cube as main.soc and
// main_metal.soc, rendered through the same gfx draw-call surface
// (SPEC § 7.4) against a window.create_vulkan window. cube.soc
// (geometry, colors, MVP math) is reused completely unchanged; the only
// differences are the create call and the shader input (SPIR-V binaries
// via gfx.compile_program_spirv instead of GLSL/MSL source — the one
// deliberate per-backend difference, per win.backend_name()'s design).
// The golden pins below are the SAME two frames at the SAME pixel
// coordinates with the SAME expected bytes as main.soc's and
// main_metal.soc's — that identity is the point: the same Socrates
// program now renders the same pixels on three graphics APIs.
//
//   ./target/release/socrates demos/glcube/main_vulkan.soc   # needs --features vulkan
//   ./target/release/socrates test demos/glcube/main_vulkan.soc
//
// Requires a Vulkan device + X server (Mesa's lavapipe under Xvfb
// counts — the vulkan CI job's environment; no GPU needed). Anywhere
// else, window.create_vulkan returns Err and this file reports one
// deterministic line and exits 0 — but its golden test is pinned to the
// *rendered* pixels, so it only passes where it can actually render.
//
// The two modules are SPIR-V 1.0, assembled word by word (generator in
// the commit's test plan) — in GLSL terms:
//   // vertex
//   layout(location = 0) in vec3 pos;
//   layout(location = 1) in vec3 color;
//   layout(location = 0) out vec3 vcolor;
//   layout(set = 0, binding = 0) uniform U { mat4 mvp; };
//   void main() {
//       vec4 p = mvp * vec4(pos, 1.0);
//       p.z = (p.z + p.w) * 0.5;   // GL clip-z [-w,+w] -> Vulkan [0,+w]
//       gl_Position = p;
//       vcolor = color;
//   }
//   // fragment
//   layout(location = 0) in vec3 vcolor;
//   layout(location = 0) out vec4 frag;
//   void main() { frag = vec4(vcolor, 1.0); }
// The clip-z remap is the same line main_metal.soc's MSL carries, for
// the same reason (SPEC § 7.3's Vulkan notes); the varying links by
// Location 0 on both sides, and the mvp member name is what
// gfx.set_uniform_mat4 resolves through the backend's SPIR-V reflection.
// Y needs no shader handling: the backend's negative-height viewport
// keeps clip-space +Y up exactly as in GL.

import cube;

let vs_words = [
    0x07230203, 0x00010000, 0x00000000, 0x00000029, 0x00000000, 0x00020011,
    0x00000001, 0x0003000E, 0x00000000, 0x00000001, 0x0009000F, 0x00000000,
    0x00000001, 0x6E69616D, 0x00000000, 0x00000002, 0x00000003, 0x00000004,
    0x00000005, 0x00040006, 0x00000011, 0x00000000, 0x0070766D, 0x00040047,
    0x00000002, 0x0000001E, 0x00000000, 0x00040047, 0x00000003, 0x0000001E,
    0x00000001, 0x00040047, 0x00000004, 0x0000001E, 0x00000000, 0x00030047,
    0x0000000F, 0x00000002, 0x00050048, 0x0000000F, 0x00000000, 0x0000000B,
    0x00000000, 0x00030047, 0x00000011, 0x00000002, 0x00050048, 0x00000011,
    0x00000000, 0x00000023, 0x00000000, 0x00040048, 0x00000011, 0x00000000,
    0x00000005, 0x00050048, 0x00000011, 0x00000000, 0x00000007, 0x00000010,
    0x00040047, 0x00000006, 0x00000022, 0x00000000, 0x00040047, 0x00000006,
    0x00000021, 0x00000000, 0x00020013, 0x00000007, 0x00030021, 0x00000008,
    0x00000007, 0x00030016, 0x00000009, 0x00000020, 0x00040017, 0x0000000A,
    0x00000009, 0x00000003, 0x00040017, 0x0000000B, 0x00000009, 0x00000004,
    0x00040018, 0x0000000C, 0x0000000B, 0x00000004, 0x00040020, 0x0000000D,
    0x00000001, 0x0000000A, 0x0004003B, 0x0000000D, 0x00000002, 0x00000001,
    0x0004003B, 0x0000000D, 0x00000003, 0x00000001, 0x00040020, 0x0000000E,
    0x00000003, 0x0000000A, 0x0004003B, 0x0000000E, 0x00000004, 0x00000003,
    0x0003001E, 0x0000000F, 0x0000000B, 0x00040020, 0x00000010, 0x00000003,
    0x0000000F, 0x0004003B, 0x00000010, 0x00000005, 0x00000003, 0x0003001E,
    0x00000011, 0x0000000C, 0x00040020, 0x00000012, 0x00000002, 0x00000011,
    0x0004003B, 0x00000012, 0x00000006, 0x00000002, 0x00040020, 0x00000013,
    0x00000002, 0x0000000C, 0x00040015, 0x00000014, 0x00000020, 0x00000001,
    0x0004002B, 0x00000014, 0x00000015, 0x00000000, 0x0004002B, 0x00000009,
    0x00000016, 0x3F800000, 0x0004002B, 0x00000009, 0x00000017, 0x3F000000,
    0x00040020, 0x00000018, 0x00000003, 0x0000000B, 0x00050036, 0x00000007,
    0x00000001, 0x00000000, 0x00000008, 0x000200F8, 0x00000019, 0x0004003D,
    0x0000000A, 0x0000001A, 0x00000002, 0x00050051, 0x00000009, 0x0000001B,
    0x0000001A, 0x00000000, 0x00050051, 0x00000009, 0x0000001C, 0x0000001A,
    0x00000001, 0x00050051, 0x00000009, 0x0000001D, 0x0000001A, 0x00000002,
    0x00070050, 0x0000000B, 0x0000001E, 0x0000001B, 0x0000001C, 0x0000001D,
    0x00000016, 0x00050041, 0x00000013, 0x0000001F, 0x00000006, 0x00000015,
    0x0004003D, 0x0000000C, 0x00000020, 0x0000001F, 0x00050091, 0x0000000B,
    0x00000021, 0x00000020, 0x0000001E, 0x00050051, 0x00000009, 0x00000022,
    0x00000021, 0x00000002, 0x00050051, 0x00000009, 0x00000023, 0x00000021,
    0x00000003, 0x00050081, 0x00000009, 0x00000024, 0x00000022, 0x00000023,
    0x00050085, 0x00000009, 0x00000025, 0x00000024, 0x00000017, 0x00060052,
    0x0000000B, 0x00000026, 0x00000025, 0x00000021, 0x00000002, 0x00050041,
    0x00000018, 0x00000027, 0x00000005, 0x00000015, 0x0003003E, 0x00000027,
    0x00000026, 0x0004003D, 0x0000000A, 0x00000028, 0x00000003, 0x0003003E,
    0x00000004, 0x00000028, 0x000100FD, 0x00010038,
];
let fs_words = [
    0x07230203, 0x00010000, 0x00000000, 0x00000012, 0x00000000, 0x00020011,
    0x00000001, 0x0003000E, 0x00000000, 0x00000001, 0x0007000F, 0x00000004,
    0x00000001, 0x6E69616D, 0x00000000, 0x00000002, 0x00000003, 0x00030010,
    0x00000001, 0x00000007, 0x00040047, 0x00000002, 0x0000001E, 0x00000000,
    0x00040047, 0x00000003, 0x0000001E, 0x00000000, 0x00020013, 0x00000004,
    0x00030021, 0x00000005, 0x00000004, 0x00030016, 0x00000006, 0x00000020,
    0x00040017, 0x00000007, 0x00000006, 0x00000003, 0x00040017, 0x00000008,
    0x00000006, 0x00000004, 0x00040020, 0x00000009, 0x00000001, 0x00000007,
    0x0004003B, 0x00000009, 0x00000002, 0x00000001, 0x00040020, 0x0000000A,
    0x00000003, 0x00000008, 0x0004003B, 0x0000000A, 0x00000003, 0x00000003,
    0x0004002B, 0x00000006, 0x0000000B, 0x3F800000, 0x00050036, 0x00000004,
    0x00000001, 0x00000000, 0x00000005, 0x000200F8, 0x0000000C, 0x0004003D,
    0x00000007, 0x0000000D, 0x00000002, 0x00050051, 0x00000006, 0x0000000E,
    0x0000000D, 0x00000000, 0x00050051, 0x00000006, 0x0000000F, 0x0000000D,
    0x00000001, 0x00050051, 0x00000006, 0x00000010, 0x0000000D, 0x00000002,
    0x00070050, 0x00000008, 0x00000011, 0x0000000E, 0x0000000F, 0x00000010,
    0x0000000B, 0x0003003E, 0x00000003, 0x00000011, 0x000100FD, 0x00010038,
];

let w = 200;
let h = 200;

fn blob(words: List[Int]) -> Bytes {
    let b = bytes(0);
    for word in words {
        b.push_u32le(word);
    }
    b
}

fn run() -> Result[Unit, String] {
    let win = window.create_vulkan("glcube", w, h)?;
    win.make_current();
    gfx.viewport(0, 0, w, h);
    gfx.set_depth_test(true); // faces occlude each other correctly as the cube turns

    let program = gfx.compile_program_spirv(blob(vs_words), blob(fs_words))?;
    gfx.use_program(program);

    let vao = gfx.create_vertex_array();
    gfx.bind_vertex_array(vao);

    let vbo = gfx.create_buffer();
    gfx.bind_buffer("vertex", vbo);
    gfx.upload_buffer("vertex", cube.vertex_bytes(), false);
    gfx.set_vertex_attrib(0, 3, 24, 0); // position: 3 floats, 24-byte stride, offset 0
    gfx.set_vertex_attrib(1, 3, 24, 12); // color: 3 floats, 24-byte stride, offset 12

    let ebo = gfx.create_buffer();
    gfx.bind_buffer("index", ebo);
    gfx.upload_buffer("index", cube.index_bytes(), false);

    let index_count = cube.indices().len();
    let aspect = w.to_float() / h.to_float();

    // Same six frames, same two pinned angles, same reasoning as
    // main.soc: frame 0 is face-on to the front face (red), frame 5
    // lands exactly face-on to the left face (blue) — both centers sit
    // deep inside one solid color, never on an edge.
    let frames = 6;
    let mut report = [];
    for frame in 0..frames {
        let angle = frame.to_float() * (math.pi / 2.0) / (frames - 1).to_float();
        gfx.clear(0.0, 0.0, 0.0, 1.0);
        gfx.set_uniform_mat4(program, "mvp", cube.mvp_at(angle, aspect));
        gfx.draw_elements(index_count, 0);
        win.swap_buffers();
        win.poll();
        if frame == 0 || frame == frames - 1 {
            let deg = (angle * 180.0 / math.pi).to_fixed(0);
            let center = gfx.read_pixels(w / 2, h / 2, 1, 1).to_list();
            let corner = gfx.read_pixels(4, 4, 1, 1).to_list();
            report.push("frame {frame} ({deg} deg): center={center} corner={corner}");
        }
    }

    win.close();
    for line in report {
        println(line);
    }
    Ok(())
}

if let Err(msg) = run() {
    println("glcube: vulkan unavailable, skipping ({msg})");
}

// Golden output for './target/release/socrates test demos/glcube/main_vulkan.soc'
// — requires `--features vulkan` on Linux with an X server + Vulkan device
// (the vulkan CI job runs it under Xvfb + lavapipe). The expected bytes are
// deliberately IDENTICAL to main.soc's OpenGL pins and main_metal.soc's
// Metal pins — the three-backend pixel-parity contract. Regenerate with:
//   ./target/release/socrates demos/glcube/main_vulkan.soc | sed 's/^/\/\/? expect: /'
//? expect: frame 0 (0 deg): center=[255, 0, 0, 255] corner=[0, 0, 0, 255]
//? expect: frame 5 (90 deg): center=[0, 0, 255, 255] corner=[0, 0, 0, 255]
