// eval — the tree-walking evaluator: values, environments, special forms
// (define / lambda / if / quote), and the builtin procedures.
//
// Every fallible step returns Result[Value, String], so a bad Lisp program
// comes back to the caller as an Err value — never a crash.

import reader;

// A runtime value. Fun carries a closure: parameters, the unevaluated
// body, and the environment the lambda was created in (lexical scope).
pub enum Value {
    Num(Int),
    BoolV(Bool),
    Sym(String),
    ListV(List[Value]),
    Fun(Closure),
    Builtin(String),
    Void,
}

pub struct Closure {
    params: List[String],
    body: reader.Sexp,
    env: Env,
}

// A scope: bindings plus a parent link. Envs are structs, so closures
// holding one see later defines in it — that is what makes recursive
// (define (fact n) ... (fact ...)) work.
pub struct Env {
    vars: Map[String, Value],
    parent: Option[Env],
}

impl Env {
    pub fn lookup(self, name: String) -> Option[Value] {
        match self.vars.get(name) {
            Some(v) -> Some(v),
            None -> match self.parent {
                Some(p) -> p.lookup(name),
                None -> None,
            },
        }
    }
}

// The toplevel environment, preloaded with the builtin procedures.
pub fn global_env() -> Env {
    let g = Env { vars: {:}, parent: None };
    let names = ["+", "-", "*", "/", "%", "=", "<", ">", "<=", ">=",
                 "cons", "car", "cdr", "list", "null?", "not"];
    for name in names {
        g.vars[name] = Value.Builtin(name);
    }
    g
}

// Render a value the way a Lisp would print it.
pub fn show(v: Value) -> String {
    match v {
        Num(n) -> str(n),
        BoolV(b) -> if b { "#t" } else { "#f" },
        Sym(s) -> s,
        ListV(items) -> "(" + items.map(show).join(" ") + ")",
        Fun(c) -> "#<lambda ({c.params.join(" ")})>",
        Builtin(name) -> "#<builtin {name}>",
        Void -> "#<void>",
    }
}

// ---- the evaluator ----

pub fn eval(e: reader.Sexp, env: Env) -> Result[Value, String] {
    match e {
        Num(n) -> Ok(Value.Num(n)),
        Sym(s) -> eval_symbol(s, env),
        Form(items) -> eval_form(items, env),
    }
}

fn eval_symbol(s: String, env: Env) -> Result[Value, String] {
    if s == "#t" { return Ok(Value.BoolV(true)); }
    if s == "#f" { return Ok(Value.BoolV(false)); }
    match env.lookup(s) {
        Some(v) -> Ok(v),
        None -> Err("unbound symbol '{s}'"),
    }
}

fn eval_form(items: List[reader.Sexp], env: Env) -> Result[Value, String] {
    if items.is_empty() {
        return Err("cannot evaluate the empty form ()");
    }
    // Special forms receive their arguments unevaluated.
    if is_head(items, "define") { return eval_define(items, env); }
    if is_head(items, "lambda") { return eval_lambda(items, env); }
    if is_head(items, "if") { return eval_if(items, env); }
    if is_head(items, "quote") {
        if items.len() != 2 { return Err("quote expects one argument"); }
        return Ok(quoted(items[1]));
    }
    // Anything else is application: evaluate head and args, then apply.
    let f = eval(items[0], env)?;
    let args: List[Value] = [];
    for a in items.slice(1, items.len()) {
        args.push(eval(a, env)?);
    }
    apply(f, args)
}

fn is_head(items: List[reader.Sexp], word: String) -> Bool {
    match items.first() {
        Some(Sym(s)) -> s == word,
        _ -> false,
    }
}

// (define name expr), or the sugar (define (name a b) body)
// which is short for (define name (lambda (a b) body)).
fn eval_define(items: List[reader.Sexp], env: Env) -> Result[Value, String] {
    if items.len() != 3 {
        return Err("define expects (define name expr) or (define (name args) body)");
    }
    match items[1] {
        Sym(name) -> {
            let v = eval(items[2], env)?;
            env.vars[name] = v;
            Ok(Value.Void)
        }
        Form(sig) -> {
            if sig.is_empty() {
                return Err("define: cannot define ()");
            }
            let name = sym_name(sig[0])?;
            let params = param_names(sig.slice(1, sig.len()))?;
            env.vars[name] = Value.Fun(Closure { params: params, body: items[2], env: env });
            Ok(Value.Void)
        }
        Num(_) -> Err("define: expected a name, got a number"),
    }
}

fn eval_lambda(items: List[reader.Sexp], env: Env) -> Result[Value, String] {
    if items.len() != 3 {
        return Err("lambda expects (lambda (params) body)");
    }
    match items[1] {
        Form(ps) -> Ok(Value.Fun(Closure { params: param_names(ps)?, body: items[2], env: env })),
        _ -> Err("lambda: parameters must be a list, got {items[1].show()}"),
    }
}

fn eval_if(items: List[reader.Sexp], env: Env) -> Result[Value, String] {
    if items.len() != 4 {
        return Err("if expects (if test then else)");
    }
    if truthy(eval(items[1], env)?) {
        eval(items[2], env)
    } else {
        eval(items[3], env)
    }
}

// Scheme truthiness: everything except #f is true.
fn truthy(v: Value) -> Bool {
    match v {
        BoolV(b) -> b,
        _ -> true,
    }
}

// A quoted expression becomes plain data: nothing is evaluated.
fn quoted(e: reader.Sexp) -> Value {
    match e {
        Num(n) -> Value.Num(n),
        Sym(s) -> Value.Sym(s),
        Form(items) -> Value.ListV(items.map(quoted)),
    }
}

fn sym_name(e: reader.Sexp) -> Result[String, String] {
    match e {
        Sym(s) -> Ok(s),
        _ -> Err("expected a symbol, got {e.show()}"),
    }
}

fn param_names(ps: List[reader.Sexp]) -> Result[List[String], String] {
    let names: List[String] = [];
    for p in ps {
        names.push(sym_name(p)?);
    }
    Ok(names)
}

// ---- application ----

// Call a function value. For a closure: bind parameters in a fresh child
// scope of the *captured* environment (lexical scoping), then eval the body.
pub fn apply(f: Value, args: List[Value]) -> Result[Value, String] {
    match f {
        Fun(c) -> {
            if args.len() != c.params.len() {
                return Err("arity mismatch: expected {c.params.len()} arguments, got {args.len()}");
            }
            let local = Env { vars: {:}, parent: Some(c.env) };
            for (name, v) in c.params.zip(args) {
                local.vars[name] = v;
            }
            eval(c.body, local)
        }
        Builtin(name) -> apply_builtin(name, args),
        _ -> Err("{show(f)} is not callable"),
    }
}

fn apply_builtin(name: String, args: List[Value]) -> Result[Value, String] {
    match name {
        "+" | "-" | "*" | "/" | "%" -> arith(name, args),
        "=" | "<" | ">" | "<=" | ">=" -> compare(name, args),
        "cons" -> b_cons(args),
        "car" -> b_car(args),
        "cdr" -> b_cdr(args),
        "list" -> Ok(Value.ListV(args)),
        "null?" -> b_null(args),
        "not" -> {
            if args.len() != 1 { return Err("not expects 1 argument"); }
            Ok(Value.BoolV(!truthy(args[0])))
        }
        _ -> Err("unknown builtin '{name}'"),
    }
}

// (+ ...) and (* ...) fold from their identity, (- x) negates, and the
// rest fold left. Fable's checked arithmetic panics on integer overflow
// and division by zero; try() turns those panics into ordinary Lisp
// errors instead of tearing down the interpreter.
fn arith(name: String, args: List[Value]) -> Result[Value, String] {
    let nums: List[Int] = [];
    for a in args {
        nums.push(as_num(name, a)?);
    }
    if nums.is_empty() && name != "+" && name != "*" {
        return Err("{name} expects at least one argument");
    }
    match try(|| arith_loop(name, nums)) {
        Ok(n) -> Ok(Value.Num(n)),
        Err(msg) -> Err("{name}: {msg}"),
    }
}

fn arith_loop(name: String, nums: List[Int]) -> Int {
    if name == "+" { return nums.fold(0, |acc, n| acc + n); }
    if name == "*" { return nums.fold(1, |acc, n| acc * n); }
    if name == "-" && nums.len() == 1 { return -nums[0]; }
    let mut acc = nums[0];
    for i in 1..nums.len() {
        if name == "-" { acc -= nums[i]; }
        else if name == "/" { acc = acc / nums[i]; }
        else { acc = acc % nums[i]; }
    }
    acc
}

// Comparisons chain like Scheme's: (< 1 2 3) is 1<2 and 2<3.
fn compare(name: String, args: List[Value]) -> Result[Value, String] {
    if args.len() < 2 { return Err("{name} expects at least 2 arguments"); }
    for i in 0..args.len() - 1 {
        let a = as_num(name, args[i])?;
        let b = as_num(name, args[i + 1])?;
        let ok = match name {
            "=" -> a == b,
            "<" -> a < b,
            ">" -> a > b,
            "<=" -> a <= b,
            _ -> a >= b,
        };
        if !ok { return Ok(Value.BoolV(false)); }
    }
    Ok(Value.BoolV(true))
}

fn as_num(who: String, v: Value) -> Result[Int, String] {
    match v {
        Num(n) -> Ok(n),
        _ -> Err("{who}: expected a number, got {show(v)}"),
    }
}

fn b_cons(args: List[Value]) -> Result[Value, String] {
    if args.len() != 2 { return Err("cons expects 2 arguments"); }
    match args[1] {
        ListV(tail) -> Ok(Value.ListV([args[0]].concat(tail))),
        _ -> Err("cons: second argument must be a list, got {show(args[1])}"),
    }
}

fn b_car(args: List[Value]) -> Result[Value, String] {
    match as_list("car", args)?.first() {
        Some(v) -> Ok(v),
        None -> Err("car of empty list"),
    }
}

fn b_cdr(args: List[Value]) -> Result[Value, String] {
    let items = as_list("cdr", args)?;
    if items.is_empty() { return Err("cdr of empty list"); }
    Ok(Value.ListV(items.slice(1, items.len())))
}

fn b_null(args: List[Value]) -> Result[Value, String] {
    if args.len() != 1 { return Err("null? expects 1 argument"); }
    match args[0] {
        ListV(items) -> Ok(Value.BoolV(items.is_empty())),
        _ -> Ok(Value.BoolV(false)),
    }
}

fn as_list(who: String, args: List[Value]) -> Result[List[Value], String] {
    if args.len() != 1 { return Err("{who} expects 1 argument"); }
    match args[0] {
        ListV(items) -> Ok(items),
        _ -> Err("{who}: expected a list, got {show(args[0])}"),
    }
}
