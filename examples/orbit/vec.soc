// 3D vectors for the orbit simulation — a Socrates module (v0.2).
// Imported by main.soc as `import vec;`.

pub struct V3 {
    x: Float,
    y: Float,
    z: Float,
}

pub fn of(x: Float, y: Float, z: Float) -> V3 {
    V3 { x: x, y: y, z: z }
}

pub fn zero() -> V3 {
    of(0.0, 0.0, 0.0)
}

impl V3 {
    pub fn add(self, o: V3) -> V3 {
        of(self.x + o.x, self.y + o.y, self.z + o.z)
    }

    pub fn sub(self, o: V3) -> V3 {
        of(self.x - o.x, self.y - o.y, self.z - o.z)
    }

    pub fn scale(self, k: Float) -> V3 {
        of(self.x * k, self.y * k, self.z * k)
    }

    pub fn dot(self, o: V3) -> Float {
        self.x * o.x + self.y * o.y + self.z * o.z
    }

    pub fn len(self) -> Float {
        self.dot(self).sqrt()
    }
}
