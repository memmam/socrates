// SPEC 2.3: unknown fields are compile errors — both in a struct literal and
// in a field access expression.
//? error: E0415
//? error: no field `z` on struct `Point`
//? error: no field `w` on struct `Point`
struct Point { x: Float, y: Float }
let p = Point { x: 1.0, y: 2.0, z: 3.0 };
let ok = Point { x: 0.0, y: 0.0 };
println(ok.w);
