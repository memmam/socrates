// SPEC §7.1 (v0.4): std.iter — lazy sequences as a pure-Socrates library.
import std.iter;

// Basic pipeline over a list.
let doubled = iter.of([1, 2, 3, 4, 5]).map(|x| x * 2).filter(|x| x > 4).collect();
println(doubled);                                //? expect: [6, 8, 10]

// Infinite sequences terminate through take.
println(iter.count_from(1).filter(|n| n % 3 == 0).take(4).collect());  //? expect: [3, 6, 9, 12]

// Laziness is real: map's side effect fires only for pulled elements.
let touched = [];
let out = iter.of([1, 2, 3, 4, 5, 6])
    .map(|x| {
        touched.push(x);
        x * 10
    })
    .take(2)
    .collect();
println(out);                                    //? expect: [10, 20]
println(touched);                                //? expect: [1, 2]

// Nothing at all runs without a consumer.
let silent = [];
let pending = iter.of([1, 2, 3]).map(|x| {
    silent.push(x);
    x
});
println(silent);                                 //? expect: []
println(pending.count());                        //? expect: 3

// fold, each, chain, zip.
println(iter.count_from(1).take(100).fold(0, |a, x| a + x));  //? expect: 5050
let seen = [];
iter.of(["a", "b"]).each(|s| seen.push(s));
println(seen);                                   //? expect: ["a", "b"]
println(iter.of([1, 2]).chain(iter.of([3])).collect());       //? expect: [1, 2, 3]
println(iter.of(["x", "y"]).zip(iter.count_from(0)).collect());  //? expect: [("x", 0), ("y", 1)]

// A hand-rolled iterator via from_fn: collatz steps from 27.
fn collatz(start: Int) -> iter.Iter[Int] {
    let mut n = start;
    iter.from_fn(|| {
        if n == 1 {
            return None;
        }
        let v = n;
        n = if n % 2 == 0 { n / 2 } else { 3 * n + 1 };
        Some(v)
    })
}
println(collatz(27).count());                    //? expect: 111
