// SPEC §7.1 (v0.7): std.set — Set[T] over structural map keys, insertion order.
import std.set;

// insert reports whether the element was new; duplicates change nothing.
let s = set.new();
println(s.insert(1));                  //? expect: true
println(s.insert(2));                  //? expect: true
println(s.insert(1));                  //? expect: false
println(s.len());                      //? expect: 2
println(s.contains(1));                //? expect: true
println(s.contains(3));                //? expect: false
println(s.to_list());                  //? expect: [1, 2]

// remove reports whether anything was there to remove.
println(s.remove(1));                  //? expect: true
println(s.remove(1));                  //? expect: false
println(s.to_list());                  //? expect: [2]
println(s.is_empty());                 //? expect: false

// Re-inserting a removed element lands at the back of the order.
println(s.insert(1));                  //? expect: true
println(s.to_list());                  //? expect: [2, 1]

// The empty set (a bare `new()` needs a type from somewhere: annotate).
let e: set.Set[Int] = set.new();
println(e.len());                      //? expect: 0
println(e.is_empty());                 //? expect: true
println(e.to_list());                  //? expect: []
println(e.remove(9));                  //? expect: false
println(e.contains(9));                //? expect: false

// from_list collapses duplicates to their first occurrence, keeping order.
println(set.from_list([3, 1, 3, 2, 1]).to_list());  //? expect: [3, 1, 2]
println(set.from_list(["b", "a", "b"]).to_list());  //? expect: ["b", "a"]

// Set algebra: new sets, deterministic order (left operand's order first).
let a = set.from_list([3, 1, 2]);
let b = set.from_list([2, 4, 3]);
println(a.union(b).to_list());         //? expect: [3, 1, 2, 4]
println(a.intersect(b).to_list());     //? expect: [3, 2]
println(a.difference(b).to_list());    //? expect: [1]
println(b.difference(a).to_list());    //? expect: [4]

// The operands are untouched.
println(a.to_list());                  //? expect: [3, 1, 2]
println(b.to_list());                  //? expect: [2, 4, 3]

// Against the empty set.
println(e.union(a).to_list());         //? expect: [3, 1, 2]
println(a.intersect(e).to_list());     //? expect: []
println(a.difference(e).to_list());    //? expect: [3, 1, 2]
println(e.difference(a).to_list());    //? expect: []

// Membership is structural: tuples make fine elements.
let pairs = set.new();
println(pairs.insert((1, "one")));     //? expect: true
println(pairs.insert((1, "one")));     //? expect: false
println(pairs.insert((1, "uno")));     //? expect: true
println(pairs.to_list());              //? expect: [(1, "one"), (1, "uno")]

// A single-element set intersected with itself.
let one = set.from_list([7]);
println(one.intersect(one).to_list()); //? expect: [7]
println(one.union(one).len());         //? expect: 1
