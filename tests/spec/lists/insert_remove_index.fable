// SPEC 8.2: insert(Int, T), remove(Int) -> T; SPEC 3.5: xs[i] read / assign.
let xs = [1, 2, 3, 4];
xs.insert(0, 0);                // at front
println(xs);                    //? expect: [0, 1, 2, 3, 4]
xs.insert(2, 99);               // in the middle
println(xs);                    //? expect: [0, 1, 99, 2, 3, 4]
xs.insert(xs.len(), 5);         // at len appends
println(xs);                    //? expect: [0, 1, 99, 2, 3, 4, 5]

println(xs.remove(0));          //? expect: 0
println(xs.remove(1));          //? expect: 99
println(xs);                    //? expect: [1, 2, 3, 4, 5]
println(xs.remove(xs.len() - 1)); //? expect: 5
println(xs);                    //? expect: [1, 2, 3, 4]

// Indexing reads and writes.
println(xs[0]);                 //? expect: 1
println(xs[xs.len() - 1]);      //? expect: 4
xs[0] = 42;
xs[3] += 100;
println(xs);                    //? expect: [42, 2, 3, 104]

// Remove down to empty.
let s = ["only"];
println(s.remove(0));           //? expect: only
println(s.is_empty());          //? expect: true
