// Nested lists: chained indexing, methods through nesting, shared inner references.
let grid = [[1, 2, 3], [4, 5, 6]];
println(grid.len());                        //? expect: 2
println(grid[1][2]);                        //? expect: 6
grid[0][1] = 20;
println(grid);                              //? expect: [[1, 20, 3], [4, 5, 6]]

// Methods compose across levels.
println(grid.map(|row| row.len()));         //? expect: [3, 3]
println(grid.map(|row| row.fold(0, |a, x| a + x))); //? expect: [24, 15]
println(grid.flat_map(|row| row.reverse())); //? expect: [3, 20, 1, 6, 5, 4]

// The same inner list stored twice is one shared object.
let row = [0];
let twice = [row, row];
row.push(1);
println(twice);                             //? expect: [[0, 1], [0, 1]]
twice[0].push(2);
println(row);                               //? expect: [0, 1, 2]
println(twice[1]);                          //? expect: [0, 1, 2]

// get on nested lists returns Option[List[Int]].
println(grid.get(0));                       //? expect: Some([1, 20, 3])
println(grid.get(5));                       //? expect: None

// Strings nested inside containers print quoted (SPEC 8.1).
let names = [["ann", "bo"], []];
println(names);                             //? expect: [["ann", "bo"], []]
println(str(names[0]));                     //? expect: ["ann", "bo"]

// A list of tuples of lists round-trips through contains structurally.
let fancy = [(1, [true]), (2, [])];
println(fancy.contains((1, [true])));       //? expect: true
println(fancy.contains((1, [false])));      //? expect: false
