// SPEC 2.2 / 3.3: a..b is half-open, a..=b is inclusive; for yields Int.
for i in 0..4 { print(i); }
println("");               //? expect: 0123
for i in 0..=4 { print(i); }
println("");               //? expect: 01234

// negative bounds
for i in -3..=-1 { print(i); print(";"); }
println("");               //? expect: -3;-2;-1;

// single-element ranges
for i in 5..6 { print(i); }
for i in 7..=7 { print(i); }
println("");               //? expect: 57

// empty ranges: the body never runs
let mut hits = 0;
for i in 5..5 { hits += 1; }
for i in 5..3 { hits += 1; }
for i in 5..=4 { hits += 1; }
for i in 3..=0 { hits += 1; }
for i in 0..0 { hits += 1; }
println(hits);             //? expect: 0
println((5..5).len());     //? expect: 0
println((7..3).to_list()); //? expect: []

// bounds may be arbitrary Int expressions
let lo = 2;
let hi = 5;
for i in lo..hi { print(i); }
println("");               //? expect: 234
let xs = [10, 20, 30];
for i in 0..xs.len() { println(xs[i]); }
//? expect: 10
//? expect: 20
//? expect: 30

// ranges are values and can be iterated more than once
let r = 1..=3;
for i in r { print(i); }
for i in r { print(i); }
println("");               //? expect: 123123
