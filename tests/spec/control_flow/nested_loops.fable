// Nested loops: break and continue bind to the innermost enclosing loop.
for i in 0..3 {
    for j in 0..3 {
        if j == i {
            continue;
        }
        if j == 2 {
            break;
        }
        println("{i},{j}");
    }
}
//? expect: 0,1
//? expect: 1,0
//? expect: 2,0
//? expect: 2,1
println("--");           //? expect: --

// breaking out of both loops needs a flag: inner break only exits the inner loop
let mut found = false;
let mut oi = 0;
while oi < 5 {
    let mut oj = 0;
    while oj < 5 {
        if oi * oj == 6 {
            found = true;
            break;
        }
        oj += 1;
    }
    if found {
        break;
    }
    oi += 1;
}
println("{oi} {found}"); //? expect: 2 true

// while nested inside for
for k in 1..=3 {
    let mut m = k;
    while m > 0 {
        print(m);
        m -= 1;
    }
    println("");
}
//? expect: 1
//? expect: 21
//? expect: 321
