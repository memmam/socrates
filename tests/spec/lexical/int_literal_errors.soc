// SPEC 1.3: out-of-range integer literals are a compile error, and hex/binary
// literals must have valid digits in range. Decimal literals are range-checked
// as i64 (`a`); hex/binary literals are parsed as the raw 64-bit bit pattern
// (v0.8, see hex_binary_bit_pattern.soc) — `b` needs a 65th bit, past even
// that, so it still overflows.
//? error: E0105
//? error: integer literal `9223372036854775808` does not fit in 64 bits
//? error: invalid hex integer literal
//? error: invalid binary integer literal
let a = 9223372036854775808;
let b = 0x1_0000_0000_0000_0000;
let c = 0x;
let d = 0b102;
