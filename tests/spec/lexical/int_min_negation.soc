// SPEC 1.3 + 3.1: unary minus is an operator, not part of the literal, so
// -9223372036854775808 is negation applied to the literal 9223372036854775808,
// which is out of range for 64-bit signed Int — a compile error.
// (Int min is written e.g. as -9223372036854775807 - 1.)
//? error: E0105
//? error: integer literal `9223372036854775808` does not fit in 64 bits
let min = -9223372036854775808;
