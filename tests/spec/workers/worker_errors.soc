// Worker failure modes: all surfaced as values, never crashes.

// A worker that panics: its thread dies, ours doesn't; join carries the
// panic message.
let p = worker.spawn("panic_worker.soc", []).unwrap();
println(p.join());                 //? expect: Err("worker exploded")
println(p.recv());                 //? expect: None

// Spawn errors are synchronous: missing file...
println(worker.spawn("no_such_worker.soc", []).is_err());   //? expect: true
// ...and compile errors (the worker never starts half-broken).
match worker.spawn("broken_worker.soc", []) {
    Ok(_) -> println("unexpectedly compiled"),
    Err(e) -> println(e.index_of("worker compile error").is_some()),
}
//? expect: true
