// SPEC 2.1, 3.1, 3.2, 8.1: IEEE-754 float behavior and float display rules.

// Float division by zero yields inf/-inf/nan (no panic).
println(1.0 / 0.0);          //? expect: inf
println(-1.0 / 0.0);         //? expect: -inf
println(0.0 / 0.0);          //? expect: nan

// nan compares unequal to everything, including itself.
let n = 0.0 / 0.0;
println(n == n);             //? expect: false
println(n != n);             //? expect: true
println(n == 1.0);           //? expect: false

// Infinities behave per IEEE-754.
let inf = 1.0 / 0.0;
println(inf == inf);         //? expect: true
println(inf > 0.0);          //? expect: true
println(-inf < 0.0);         //? expect: true
println(inf + -inf);         //? expect: nan
println(1e300 * 1e300);      //? expect: inf
println(-1e300 * 1e300);     //? expect: -inf

// Whole floats always display with a decimal point.
println(3.0);                //? expect: 3.0
println(1.5 + 1.5);          //? expect: 3.0
println(100.0 / 4.0);        //? expect: 25.0
println(1e9);                //? expect: 1000000000.0

// Shortest round-trip representation.
println(0.1 + 0.2);          //? expect: 0.30000000000000004
println(1.0 / 3.0);          //? expect: 0.3333333333333333
println(2.5e-3);             //? expect: 0.0025

// Negative zero exists and compares equal to positive zero.
println(-0.0);               //? expect: -0.0
println(0.0 == -0.0);        //? expect: true
