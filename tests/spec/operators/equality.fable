// SPEC 3.2: == / != are structural (deep) for all types.
struct Point { x: Float, y: Float }

// Lists compare element-wise, recursively.
println([1, 2, 3] == [1, 2, 3]);              //? expect: true
println([1, 2] == [1, 3]);                    //? expect: false
println([[1], [2]] == [[1], [2]]);            //? expect: true
let empty1: List[Int] = [];
let empty2: List[Int] = [];
println(empty1 == empty2);                    //? expect: true

// Maps compare by contents, not by insertion order.
println({"a": 1, "b": 2} == {"b": 2, "a": 1});  //? expect: true
println({"a": 1} == {"a": 2});                //? expect: false
println({"a": 1} != {"a": 1, "b": 2});        //? expect: true

// Tuples compare component-wise, recursively.
println((1, "two") == (1, "two"));            //? expect: true
println((1, "two") == (1, "three"));          //? expect: false
println((1, (2, "x")) == (1, (2, "x")));      //? expect: true

// Structs compare by field values, not by object identity.
println(Point { x: 1.0, y: 2.0 } == Point { x: 1.0, y: 2.0 });  //? expect: true
println(Point { x: 1.0, y: 2.0 } == Point { x: 1.0, y: 3.0 });  //? expect: false

// Enum values compare by variant and payload.
println(Some(1) == Some(1));                  //? expect: true
let none: Option[Int] = None;
println(Some(1) == none);                     //? expect: false
println(Ok(1) == Ok(1));                      //? expect: true

// Unit and Bool.
println(() == ());                            //? expect: true
println(true != false);                       //? expect: true

// IEEE float equality applies inside containers too: [nan] != [nan].
println([0.0 / 0.0] == [0.0 / 0.0]);          //? expect: false
