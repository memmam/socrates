// SPEC 3.1: the full precedence table, associativity, unary operators,
// and integer division/modulo truncation toward zero.

// Multiplicative (7) binds tighter than additive (6).
println(1 + 2 * 3);                          //? expect: 7
println((1 + 2) * 3);                        //? expect: 9
println(10 + 3 % 2);                         //? expect: 11
println(10 % 3 + 1);                         //? expect: 2

// Levels 6 and 7 are left-associative.
println(10 - 4 - 3);                         //? expect: 3
println(100 / 10 / 2);                       //? expect: 5
println(7 / 2 * 2);                          //? expect: 6
println(2 * 3 % 4);                          //? expect: 2

// Range (5) binds looser than additive (6): 1 + 1 .. 2 * 3 is (2)..(6).
println((1 + 1..2 * 3).to_list());           //? expect: [2, 3, 4, 5]
println((1..=3).to_list());                  //? expect: [1, 2, 3]

// Comparison (4) binds looser than additive; equality (3) looser than comparison.
println(2 + 3 == 5);                         //? expect: true
println(1 < 2 == true);                      //? expect: true

// && (2) binds tighter than || (1); equality (3) tighter than &&.
println(false == false && true);             //? expect: true
println(true || false && false);             //? expect: true
println(1 + 2 == 4 || 2 * 2 == 4 && true);   //? expect: true

// Unary (8) binds tighter than binary arithmetic but looser than calls (9):
// -2.pow(2) is -(2.pow(2)).
println(-2 * 3);                             //? expect: -6
println(-2.pow(2));                          //? expect: -4
println((-2).pow(2));                        //? expect: 4
println(!true == false);                     //? expect: true
println(!!true);                             //? expect: true
println(!(1 == 2));                          //? expect: true
println(- -5);                               //? expect: 5
println(2 - -3);                             //? expect: 5
let x = 5;
println(-x);                                 //? expect: -5
println(-3.0);                               //? expect: -3.0
let f = 2.5;
println(-f * 2.0);                           //? expect: -5.0
println((-1..3).to_list());                  //? expect: [-1, 0, 1, 2]

// Integer division truncates toward zero; % takes the sign of the dividend.
println(7 / 2);                              //? expect: 3
println(-7 / 2);                             //? expect: -3
println(7 / -2);                             //? expect: -3
println(-7 / -2);                            //? expect: 3
println(-7 % 2);                             //? expect: -1
println(7 % -2);                             //? expect: 1
