// A nested helper module (imported as `lib.vec`), itself importing a sibling
// via a relative path.
import pair;

pub struct V2[T] {
    x: T,
    y: T,
}

impl V2[T] {
    pub fn swap(self) -> V2[T] {
        V2 { x: self.y, y: self.x }
    }
}

pub fn make(x: Int, y: Int) -> V2[Int] {
    V2 { x: x, y: y }
}

pub fn to_pair(v: V2[Int]) -> pair.Pair {
    pair.Pair { a: v.x, b: v.y }
}
