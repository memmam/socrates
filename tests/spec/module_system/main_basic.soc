// SPEC §5.2 (v0.2): multi-file modules. `import geo;` loads `geo.soc` from
// this file's directory; members are reached as `geo.name`, types as
// `geo.Type`, and enum variants as `geo.Shape.Variant`.
import geo;

// Qualified struct literal + qualified type annotation.
let p: geo.Point = geo.Point { x: 3.0, y: 4.0 };

// Module function call.
println(geo.area(geo.Shape.Circle(1.0)));         //? expect: 3.141592653589793
println(geo.area(geo.Shape.Rect(2.0, 3.0)));      //? expect: 6.0
println(geo.area(geo.Shape.Empty));               //? expect: 0.0

// Methods defined in the module's impl blocks dispatch on the value's type,
// no qualification needed.
println(p.dist(geo.origin()));                    //? expect: 5.0

// Module globals (read-only from outside).
println(geo.area(geo.unit_square));               //? expect: 1.0

// Module functions are first-class values.
let f = geo.area;
println(f(geo.Shape.Rect(4.0, 2.0)));             //? expect: 8.0

// Qualified and unqualified (type-directed) patterns both work.
fn describe(s: geo.Shape) -> String {
    match s {
        geo.Shape.Circle(r) -> "circle {r}",
        Rect(w, h) -> "rect {w}x{h}",
        geo.Shape.Empty -> "empty",
    }
}
println(describe(geo.Shape.Circle(2.0)));         //? expect: circle 2.0
println(describe(geo.Shape.Rect(1.0, 2.0)));      //? expect: rect 1.0x2.0
println(describe(geo.Shape.Empty));               //? expect: empty

// Qualified struct patterns.
match p {
    geo.Point { x, .. } -> println("x is {x}"),   //? expect: x is 3.0
}

// Module state is shared: every caller sees the same globals.
geo.bump();
geo.bump();
println(geo.bump());                              //? expect: 3

// Option/Result from module functions compose with `?`.
fn total(a: String, b: String) -> Option[Float] {
    Some(geo.parse_coord(a)? + geo.parse_coord(b)?)
}
println(total("1.5", "2.5"));                     //? expect: Some(4.0)
println(total("1.5", "nope"));                    //? expect: None
