// BUG: the compiler itself crashes (Rust panic, not a Socrates diagnostic or
// Socrates panic) on a spec-legal program:
//
//   thread 'main' panicked at src/compiler.rs:509:32:
//   attempt to subtract with overflow
//
// Trigger: a `return <expr>;` statement that executes when the function has
// zero locals in scope (a zero-parameter fn or lambda whose body begins with
// `return`). In StmtKind::Return the compiler does `set_depth(d - 1)` and the
// compile-time stack depth underflows. Minimal repros:
//
//   fn f() -> Int { return 9; }              // crashes
//   let f = || -> Int { return 9; };         // crashes
//
// Adding any parameter or a prior local avoids it:
//   fn f(a: Int) -> Int { return a; }        // works
//   fn f() -> Int { let x = 1; return 9; }   // works
//
// SPEC § 3.3: "`return expr` / `return` exits the enclosing function" — this
// program should compile and print 9 (exit code 0), not abort the compiler.
let f = || -> Int { return 9; };
println(f());        //? expect: 9
