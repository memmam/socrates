// SPEC 2.2: tuples are immutable, value-semantics compounds of 2+ elements,
// accessed by .0/.1/... or pattern matching.
let t = (1, "two", 3.5, true);
println(t.0);                     //? expect: 1
println(t.1);                     //? expect: two
println(t.2);                     //? expect: 3.5
println(t.3);                     //? expect: true

// SPEC 8.1: tuple display; strings nested inside containers are quoted.
println(t);                       //? expect: (1, "two", 3.5, true)
println(str((1, 2)));             //? expect: (1, 2)
println(("a\nb", "c\td"));        //? expect: ("a\nb", "c\td")

// Nested tuple access chains.
let nested = ((1, 2), (3, (4, 5)));
println(nested.0.1);              //? expect: 2
println(nested.1.1.0);            //? expect: 4
println(nested.1);                //? expect: (3, (4, 5))

// SPEC 3.2: structural equality.
println((1, 2) == (1, 2));        //? expect: true
println((1, 2) == (2, 1));        //? expect: false
println((1, 2) != (2, 1));        //? expect: true
println((1, ("a", 2.0)) == (1, ("a", 2.0)));  //? expect: true
println((1, ("a", 2.0)) == (1, ("b", 2.0)));  //? expect: false

// SPEC 4: irrefutable let destructuring of tuples, including nested.
let (a, b) = (10, "ten");
println(a);                       //? expect: 10
println(b);                       //? expect: ten
let ((x, y), z) = ((1, 2), 3);
println(x + y + z);               //? expect: 6

// Tuples from expressions; interpolation uses str() rules.
let pair = (a + 1, b + "!");
println("pair = {pair}");         //? expect: pair = (11, "ten!")

// Match on tuples.
let msg = match (1, 2) {
    (0, _) -> "zero first",
    (_, 2) -> "two second",
    _ -> "other",
};
println(msg);                     //? expect: two second
