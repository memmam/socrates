// SPEC 1.3: interpolation embeds ANY expression, converted with str() rules;
// nested string literals (themselves interpolated) are allowed inside { };
// a literal `{` is written \{.
let name = "Ada";
let xs = "a,b,c";
println("hi {name}");                               //? expect: hi Ada
println("len={name.len()}, up={name.to_upper()}");  //? expect: len=3, up=ADA
println("parts: {xs.split(",").len()}");            //? expect: parts: 3
println("{1 + 2 * 3} and {(1 + 2) * 3}");           //? expect: 7 and 9
println("cond: {if name == "Ada" { "yes" } else { "no" }}");  //? expect: cond: yes
println("nested {"[{name.to_lower()}]"} done");     //? expect: nested [ada] done
println("deep {"a {"b {1 + 1}"} c"} end");          //? expect: deep a b 2 c end
println("slice={xs.slice(0, 1)}");                  //? expect: slice=a
println("opt={xs.index_of("b")}");                  //? expect: opt=Some(2)
println("brace \{literal} vs {name}");              //? expect: brace {literal} vs Ada
println("float={1.5 * 2.0}, bool={1 < 2}");         //? expect: float=3.0, bool=true
println("list={xs.split(",")}");                    //? expect: list=["a", "b", "c"]
