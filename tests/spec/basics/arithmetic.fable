println(1 + 2 * 3);        //? expect: 7
println((1 + 2) * 3);      //? expect: 9
println(7 / 2);            //? expect: 3
println(-7 / 2);           //? expect: -3
println(7 % 3);            //? expect: 1
println(2.5 * 4.0);        //? expect: 10.0
println(1.0 / 0.0);        //? expect: inf
println(10 - 3 - 4);       //? expect: 3
