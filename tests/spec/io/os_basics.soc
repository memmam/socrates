// SPEC §7 (v0.3): the os namespace — args, env, run, time. (`os.exit` ends
// the process, so it is exercised manually rather than in this suite.)

// No arguments were passed to this test program.
println(os.args());                          //? expect: []

// PATH exists everywhere we run; a made-up variable does not.
println(os.env("PATH").is_some());           //? expect: true
println(os.env("SOCRATES_NO_SUCH_VAR_XYZ"));    //? expect: None

// os.time() is seconds since the Unix epoch.
println(os.time() > 1000000000.0);           //? expect: true

// Subprocesses: exit code, stdout, and stderr come back in a tuple.
match os.run("echo", ["hello", "socrates"]) {
    Ok(t) -> println("{t.0}|{t.1.trim()}"),  //? expect: 0|hello socrates
    Err(e) -> println("run failed: {e}"),
}

// A missing binary is an Err, not a panic.
let outcome = match os.run("socrates-no-such-binary-xyz", []) {
    Ok(_) -> "ran?!",
    Err(_) -> "no such binary",
};
println(outcome);                            //? expect: no such binary

// A failing command still returns Ok — with its nonzero exit code.
match os.run("sh", ["-c", "exit 3"]) {
    Ok(t) -> println(t.0),                   //? expect: 3
    Err(e) -> println("run failed: {e}"),
}
