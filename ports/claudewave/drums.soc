// claudewave.drums — Socrates port of upstream lib/drums.py (byte-for-byte
// copy vendored at ports/claudewave/upstream/drums.py).
//
// Synthesized drum kit — kick, brush snare, snap, shaker, hi-hat, congas
// (mono), plus render_drums_on_beats (stereo beat-grid placement).
// Function-for-function port; expression order follows upstream (see
// ports/pyl/CONTRACT.md). Socrates has no default arguments: callers pass
// the upstream defaults explicitly (documented per function).

import pyl.nd;
import pyl.signal;
import pyl.rand;

let mut rng: rand.Stream = rand.from_vals([]);

pub fn set_stream(s: rand.Stream) { rng = s; }

// Defaults: f_start=105, f_end=52, dur_s=0.30. Stream-fed (randn click).
pub fn voice_kick(sr: Int, f_start: Float, f_end: Float, dur_s: Float) -> nd.Nd {
    let srf = sr.to_float();
    let n = (dur_s * srf).to_int();
    let t = nd.arange(n).divs(srf);
    let pitch = t.muls(-25.0).expv().muls(f_start - f_end).adds(f_end);
    let y = pitch.cumsum().muls(2.0 * math.pi).divs(srf).sinv();
    let click = nd.zeros(n);
    click.set_range(0, rng.randn(90).muls(0.4));
    let amp = t.muls(-8.0).expv();
    (y.mul(amp) + click.mul(t.muls(-90.0).expv()).muls(0.3)).muls(0.75)
}

// Default dur_s=0.22. Stream-fed (randn body).
pub fn voice_brush_snare(sr: Int, dur_s: Float) -> nd.Nd {
    let srf = sr.to_float();
    let n = (dur_s * srf).to_int();
    let t = nd.arange(n).divs(srf);
    let noise = rng.randn(n);
    let sos = signal.butter(2, 250.0 / (srf / 2.0), 5500.0 / (srf / 2.0), "band");
    let body = signal.sosfilt(sos, noise);
    let tone = t.muls(2.0 * math.pi * 210.0).sinv().muls(0.22);
    let amp = t.muls(-14.0).expv();
    (body.mul(amp) + tone.mul(amp).muls(0.45)).muls(0.5)
}

// Default dur_s=0.12. Stream-fed.
pub fn voice_snap(sr: Int, dur_s: Float) -> nd.Nd {
    let srf = sr.to_float();
    let n = (dur_s * srf).to_int();
    let t = nd.arange(n).divs(srf);
    let noise = rng.randn(n);
    let sos = signal.butter(2, 1200.0 / (srf / 2.0), 8000.0 / (srf / 2.0), "band");
    let y = signal.sosfilt(sos, noise);
    let env = t.muls(-50.0).expv();
    y.mul(env).muls(0.6)
}

// Default dur_s=0.08. Stream-fed.
pub fn voice_shaker(sr: Int, dur_s: Float) -> nd.Nd {
    let srf = sr.to_float();
    let n = (dur_s * srf).to_int();
    let t = nd.arange(n).divs(srf);
    let noise = rng.randn(n);
    let sos = signal.butter(3, 4500.0 / (srf / 2.0), 10000.0 / (srf / 2.0), "band");
    let y = signal.sosfilt(sos, noise);
    let env = t.muls(-60.0).expv().mul(t.muls(-550.0).expv().k_minus(1.0));
    y.mul(env).muls(0.24)
}

// Default dur_s=0.06. Stream-fed. Order-3 high-pass at 8500 Hz.
pub fn voice_hat(sr: Int, dur_s: Float) -> nd.Nd {
    let srf = sr.to_float();
    let n = (dur_s * srf).to_int();
    let t = nd.arange(n).divs(srf);
    let noise = rng.randn(n);
    let sos = signal.butter(3, 8500.0 / (srf / 2.0), 0.0, "high");
    let y = signal.sosfilt(sos, noise);
    let env = t.muls(-130.0).expv();
    y.mul(env).muls(0.26)
}

// Defaults: dur_s=0.16, f=250. Deterministic (no filter, no random).
pub fn voice_conga(sr: Int, dur_s: Float, f: Float) -> nd.Nd {
    let srf = sr.to_float();
    let n = (dur_s * srf).to_int();
    let t = nd.arange(n).divs(srf);
    let pitch = t.muls(-40.0).expv().muls(f * 1.5 - f).adds(f);
    let y = pitch.cumsum().muls(2.0 * math.pi).divs(srf).sinv();
    let amp = t.muls(-20.0).expv();
    y.mul(amp).muls(0.45)
}

// Render a stereo drum track placing hits on the beat_times grid.
//
// sections: list of (start_s, end_s, gain, style); style is one of
// "off", "light", "groove", "lift" (see upstream docstring). tight:
// if false, jitter hits by +/-5ms (one stream draw per placed beat).
// Default tight=true.
pub fn render_drums_on_beats(beat_times: List[Float], total_s: Float, sr: Int,
                             sections: List[(Float, Float, Float, String)],
                             tight: Bool) -> nd.Nd {
    let srf = sr.to_float();
    let n_total = (total_s * srf).to_int();
    let l = nd.zeros(n_total);
    let r = nd.zeros(n_total);
    let kick = voice_kick(sr, 105.0, 52.0, 0.30);
    let snare = voice_brush_snare(sr, 0.22);
    let shaker = voice_shaker(sr, 0.08);
    let hat = voice_hat(sr, 0.06);

    // L[si:ei] += y[:ei-si]*gl; R likewise (add_range clips at the end)
    let hit = |t: Float, y: nd.Nd, pan: Float, gain: Float| {
        let si = (t * srf).to_int();
        let gl = math.cos((pan + 1.0) * math.pi / 4.0) * gain;
        let gr = math.sin((pan + 1.0) * math.pi / 4.0) * gain;
        l.add_range(si, y, gl);
        r.add_range(si, y, gr);
    };

    let section_at = |t: Float| -> (Float, String) {
        let mut g = 0.0;
        let mut sty = "off";
        for (s, e, gg, style) in sections {
            if s <= t && t < e {
                g = gg;
                sty = style;
                break;
            }
        }
        (g, sty)
    };

    for (i, t) in beat_times.enumerate() {
        if t >= total_s { break; }
        let (g, style) = section_at(t);
        if g <= 0.01 || style == "off" { continue; }
        let bib = i % 4;
        let jitter = if tight { 0.0 } else { (rng.random_() - 0.5) * 0.005 };
        let tj = t + jitter;
        hit(tj, shaker, rng.uniform(-0.25, 0.25), 0.60 * g);
        if style == "groove" || style == "lift" {
            if i + 1 < beat_times.len() {
                let th = (beat_times[i] + beat_times[i + 1]) / 2.0;
                hit(th, shaker, rng.uniform(-0.25, 0.25), 0.45 * g);
                if bib == 1 || bib == 3 {
                    hit(th, hat, rng.uniform(-0.15, 0.15), 0.38 * g);
                }
            }
            if bib == 0 || bib == 2 {
                hit(tj, kick, 0.0, 0.80 * g);
            }
            if bib == 1 || bib == 3 {
                hit(tj, snare, 0.06, 0.48 * g);
            }
            if style == "lift" && bib == 3 && (i / 4) % 4 == 3 && i + 1 < beat_times.len() {
                // fill before next bar
                let th = (beat_times[i] + beat_times[i + 1]) / 2.0;
                hit(th, snare, -0.05, 0.35 * g);
            }
        } else if style == "light" {
            if bib == 0 {
                hit(tj, kick, 0.0, 0.68 * g);
            }
            if bib == 2 {
                hit(tj, snare, 0.06, 0.42 * g);
            }
        }
    }
    nd.stack2(l, r)
}
