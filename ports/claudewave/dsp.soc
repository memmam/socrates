// claudewave.dsp — Socrates port of upstream lib/dsp.py (byte-for-byte copy
// vendored at ports/claudewave/upstream/dsp.py).
//
// DSP helpers: tape warmth, sidechain pump, vinyl crackle, hiss.
// Function-for-function port with upstream expression order
// (see ports/pyl/CONTRACT.md). Socrates has no default arguments: callers
// pass the upstream defaults explicitly (documented per function).
//
// OUT OF SCOPE (declared in the port contract): load_stereo and
// resample_rate need soundfile / scipy.signal.resample, which are not
// part of the pyl layer; they are intentionally not ported. Everything
// else in dsp.py is below.

import pyl.nd;
import pyl.signal;
import pyl.rand;

let mut rng: rand.Stream = rand.from_vals([]);

pub fn set_stream(s: rand.Stream) { rng = s; }

// Default target_db=-18.0.
pub fn rms_normalize(y: nd.Nd, target_db: Float) -> nd.Nd {
    let rms = (y.mul(y).mean_all() + 1e-12).sqrt();
    y.muls(math.pow(10.0, target_db / 20.0) / (rms + 1e-12))
}

// Cassette wow+flutter via sample-position modulation. Defaults:
// rate_hz=0.22, depth=32.0, flutter_rate=5.0, flutter_depth=5.0.
pub fn tape_wobble(y: nd.Nd, sr: Int, rate_hz: Float, depth: Float,
                   flutter_rate: Float, flutter_depth: Float) -> nd.Nd {
    let n = y.frames();
    let t = nd.arange(n).divs(sr.to_float());
    let mod = t.muls(2.0 * math.pi * rate_hz).adds(0.9).sinv().muls(depth)
        + t.muls(2.0 * math.pi * flutter_rate).adds(0.2).sinv().muls(flutter_depth);
    let idx = (nd.arange(n) + mod).clip(0.0, (n - 2).to_float());
    y.take_lerp(idx)
}

// Synthwave-style breathing: volume dip on every beat, smooth recovery.
// Defaults: bpm=90, depth=0.15.
pub fn sidechain_pump(y: nd.Nd, sr: Int, bpm: Int, depth: Float) -> nd.Nd {
    let beat = 60.0 / bpm.to_float();
    let t = nd.arange(y.frames()).divs(sr.to_float());
    let tb = t.divs(beat);
    let phase = tb.sub(tb.floorv());
    let rise = phase.muls(depth).divs(0.08).adds(1.0 - depth);
    let fall = phase.k_minus(0.08).muls(6.0).expv().muls(depth).k_minus(1.0);
    let env = nd.where_lt(phase, 0.08, rise, fall);
    y.mul_env(env)
}

// Vinyl crackle layer: stereo, mono-equal-both-channels. Defaults:
// density=90.0 (pops per second), level=0.03. Stream-fed
// (randint/uniform/choice pops + randn hiss).
pub fn vinyl_crackle(dur_s: Float, sr: Int, density: Float, level: Float) -> nd.Nd {
    let srf = sr.to_float();
    let n = (dur_s * srf).to_int();
    let out = nd.zeros(n);
    for _ in 0..(density * dur_s).to_int() {
        let p = rng.randint(0, n - 3);
        let a = rng.uniform(0.2, 1.0) * level;
        out.set(p, 0, out.get(p, 0) + a * rng.choice_pm1());
        out.set(p + 1, 0, out.get(p + 1, 0) + a * 0.3 * rng.choice_pm1());
    }
    let hiss0 = rng.randn(n).muls(level).muls(0.25);
    let sos = signal.butter(2, 500.0 / (srf / 2.0), 6000.0 / (srf / 2.0), "band");
    let hiss = signal.sosfilt(sos, hiss0);
    let mono = out + hiss;
    nd.stack2(mono, mono)
}

// Soft band-limited tape hiss, stereo-equal. Default level=0.010.
pub fn cassette_hiss(dur_s: Float, sr: Int, level: Float) -> nd.Nd {
    let srf = sr.to_float();
    let n = (dur_s * srf).to_int();
    let h0 = rng.randn(n).muls(level);
    let sos = signal.butter(2, 1200.0 / (srf / 2.0), 8000.0 / (srf / 2.0), "band");
    let h = signal.sosfilt(sos, h0);
    nd.stack2(h, h)
}

// Zero-pad stereo array up to n samples (and truncate past n).
pub fn pad_to(y: nd.Nd, n: Int) -> nd.Nd {
    y.pad_end(n)
}

// Linear fade-in / fade-out on an already-mixed stereo track. Defaults:
// fade_in_s=2.5, fade_out_s=6.0.
pub fn mix_fades(mix: nd.Nd, sr: Int, fade_in_s: Float, fade_out_s: Float) -> nd.Nd {
    let srf = sr.to_float();
    let n = mix.frames();
    let env = nd.ones(n);
    let fi = (fade_in_s * srf).to_int();
    let fo = (fade_out_s * srf).to_int();
    if fi > 0 { env.set_range(0, nd.linspace(0.0, 1.0, fi)); }
    if fo > 0 && fo < n { env.set_range(n - fo, nd.linspace(1.0, 0.0, fo)); }
    mix.mul_env(env)
}

// Hard-clip guard: if peak > target, divide so peak == target. Default
// target_peak=0.97.
pub fn limit_peak(y: nd.Nd, target_peak: Float) -> nd.Nd {
    let peak = y.max_abs_all();
    if peak > target_peak {
        return y.divs(peak).muls(target_peak);
    }
    y
}
