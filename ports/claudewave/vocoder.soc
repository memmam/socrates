// claudewave.vocoder — Socrates port of upstream lib/vocoder.py
// (byte-for-byte copy vendored at ports/claudewave/upstream/vocoder.py).
//
// 18-band channel vocoder + a chord-following carrier generator.
// Function-for-function port with upstream expression order (see
// ports/pyl/CONTRACT.md). Socrates has no default arguments: callers pass
// the upstream defaults explicitly (documented per function).
//
// Upstream's `if name is None: continue` chord guard maps to any
// unparseable name (e.g. ""): chord_voicing_midi returns [] and the bar
// is skipped the same way.

import pyl.nd;
import pyl.signal;
import pyl.rand;
import synths;

let mut rng: rand.Stream = rand.from_vals([]);

pub fn set_stream(s: rand.Stream) { rng = s; }

// Continuous chord carrier: two-octave stacked-saw voicings holding each
// chord for its full bar, +/-7-cent detune and stereo spread; no
// attack/release envelope. bar_chords: list of (start_s, end_s, name).
// Defaults: pitch_mult=1.0, base_midi=48. Stream-fed (one random()
// phase per pitch per detune). Returns stereo.
pub fn render_vocoder_carrier(bar_chords: List[(Float, Float, String)], total_s: Float,
                              sr: Int, pitch_mult: Float, base_midi: Int) -> nd.Nd {
    let srf = sr.to_float();
    let n_total = (total_s * srf).to_int();
    let l = nd.zeros(n_total);
    let r = nd.zeros(n_total);

    for (bs, be, name) in bar_chords {
        if bs >= total_s { break; }
        let pitches0 = synths.chord_voicing_midi(name, base_midi);
        if pitches0.len() == 0 { continue; }
        // two-octave stack for broad harmonic content
        let pitches = pitches0.clone();
        for p in pitches0 { pitches.push(p + 12); }

        let bs_i = (bs * srf).to_int();
        let be_i = n_total.min(((be + 0.2) * srf).to_int());
        let n_bar = be_i - bs_i;
        if n_bar <= 0 { continue; }
        let t_bar = nd.arange(n_bar).divs(srf);
        let xfade = (0.08 * srf).to_int();
        let env = nd.ones(n_bar);
        if n_bar > 2 * xfade {
            env.set_range(0, nd.linspace(0.0, 1.0, xfade));
            env.set_range(n_bar - xfade, nd.linspace(1.0, 0.0, xfade));
        }

        for p in pitches {
            let f = synths.midi_to_hz(p, pitch_mult);
            for (det_cents, pan) in [(-7.0, -0.3), (7.0, 0.3), (0.0, 0.0)] {
                let fd = f * math.pow(2.0, det_cents / 1200.0);
                let ph = rng.random_();
                let tf = t_bar.muls(fd).adds(ph);
                let saw = tf.sub(tf.adds(0.5).floorv()).muls(2.0);
                let gl = math.cos((pan + 1.0) * math.pi / 4.0);
                let gr = math.sin((pan + 1.0) * math.pi / 4.0);
                let se = saw.mul(env);
                // L[bs_i:be_i] += saw * env * gl * 0.1 (R likewise)
                l.add_range(bs_i, se.muls(gl).muls(0.1), 1.0);
                r.add_range(bs_i, se.muls(gr).muls(0.1), 1.0);
            }
        }
    }

    // gentle low-pass to tame the top end before vocoder bands
    let sos = signal.butter(2, 10000.0 / (srf / 2.0), 0.0, "low");
    let lf = signal.sosfilt(sos, l);
    let rf = signal.sosfilt(sos, r);
    nd.stack2(lf, rf)
}

// Classic channel vocoder. modulator/carrier: stereo. Defaults:
// n_bands=18, fmin=80.0, fmax=9000.0, env_lp_hz=30.0, band_gain=5.0.
pub fn channel_vocoder(modulator: nd.Nd, carrier: nd.Nd, sr: Int, n_bands: Int,
                       fmin: Float, fmax: Float, env_lp_hz: Float, band_gain: Float) -> nd.Nd {
    let srf = sr.to_float();
    // modulator.mean(axis=1)
    let mod_mono = (modulator.channel(0) + modulator.channel(1)).divs(2.0);
    let bands = nd.geomspace(fmin, fmax, n_bands + 1);
    let out_l = nd.zeros(carrier.frames());
    let out_r = nd.zeros(carrier.frames());
    let sos_env = signal.butter(2, env_lp_hz / (srf / 2.0), 0.0, "low");

    for i in 0..n_bands {
        let lo = bands.data[i];
        let hi = bands.data[i + 1];
        let sos = signal.butter(4, lo / (srf / 2.0),
                                (hi / (srf / 2.0)).min(0.99), "band");
        let voc_band = signal.sosfilt(sos, mod_mono);
        let env = signal.sosfilt(sos_env, voc_band.absv()).muls(band_gain);
        let car_l = signal.sosfilt(sos, carrier.channel(0));
        let car_r = signal.sosfilt(sos, carrier.channel(1));
        out_l.add_range(0, car_l.mul(env), 1.0);
        out_r.add_range(0, car_r.mul(env), 1.0);
    }
    nd.stack2(out_l, out_r)
}

// Ring modulation: multiply by a sine carrier. mix=0 dry, mix=1 all
// ring. Defaults: freq_hz=82.0, mix=0.25.
pub fn ring_modulate(y: nd.Nd, sr: Int, freq_hz: Float, mix: Float) -> nd.Nd {
    let t = nd.arange(y.frames()).divs(sr.to_float());
    let mod = t.muls(2.0 * math.pi * freq_hz).sinv();
    y.muls(1.0 - mix) + y.mul_env(mod).muls(mix)
}
