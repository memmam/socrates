// claudewave battery — renders the same 32 items as
// ports/claudewave/reference/run_upstream.py, from the Socrates port, for
// numeric cross-validation against the shim-run upstream ground truth.
//
// Usage:
//   SOCRATES_PATH=ports CLAUDEWAVE_STREAM=<rand_stream.txt> \
//       socrates ports/claudewave/battery.soc OUTDIR [ITEM]
//
// CLAUDEWAVE_STREAM points at the stream produced by
// ports/claudewave/reference/gen_stream.py (a runtime artifact, never
// committed). Battery item i seeks the shared stream cursor to offset
// i*100000 before rendering, exactly like run_upstream.py, so every
// item is independently reproducible. Outputs OUTDIR/<item>.paw and
// OUTDIR/chords.txt (+ manifest.txt). The optional ITEM argument
// restricts the .paw files written to that one item (all items are
// still built, keeping manifests comparable).

import pyl.nd;
import pyl.rand;
import pyl.audio;
import synths;
import drums;
import dsp;
import choppers;
import ambience;
import vocoder;

let item_stride = 100000;

// ---- deterministic helper buffers (no stream draws) ---------------------

// 0.5 s stereo at 8 kHz: rhodes left, fm lead right
fn base_stereo_8k() -> nd.Nd {
    nd.stack2(synths.voice_rhodes(220.0, 0.5, 8000, 0.75),
              synths.voice_fm_lead(220.0, 0.5, 8000, 0.8))
}

// 1.0 s stereo at 8 kHz: rhodes left, bell right
fn chop_base_8k() -> nd.Nd {
    nd.stack2(synths.voice_rhodes(220.0, 1.0, 8000, 0.75),
              synths.voice_bell(220.0, 1.0, 8000, 0.5))
}

// 0.5 s stereo at 22050: rhodes left, fm lead right
fn mod_stereo_22k() -> nd.Nd {
    nd.stack2(synths.voice_rhodes(220.0, 0.5, 22050, 0.75),
              synths.voice_fm_lead(330.0, 0.5, 22050, 0.8))
}

let beats = [0.0, 0.25, 0.5, 0.75, 1.0, 1.25, 1.5, 1.75];
let sections = [(0.0, 0.75, 1.0, "groove"),
                (0.75, 1.5, 0.9, "lift"),
                (1.5, 2.0, 0.8, "light")];
let carrier_chords_08 = [(0.0, 0.4, "Am7"), (0.4, 0.8, "Fmaj7")];
let carrier_chords_05 = [(0.0, 0.25, "Am7"), (0.25, 0.5, "Fmaj7")];

// ---- the battery (must stay in lockstep with run_upstream.py) -----------

let names = [
    "env_adsr", "voice_rhodes_220", "voice_sub_220", "voice_bell_220",
    "voice_fm_lead_220", "voice_slap_bass_110", "voice_juno_pad_220",
    "voice_whistle_880", "drum_kick", "drum_brush_snare", "drum_snap",
    "drum_shaker", "drum_hat", "drum_conga", "drums_on_beats",
    "dsp_rms_normalize", "dsp_tape_wobble", "dsp_sidechain_pump",
    "dsp_vinyl_crackle", "dsp_cassette_hiss", "dsp_pad_to", "dsp_mix_fades",
    "dsp_limit_peak", "chop_extract_hook", "chop_place_hook_loops",
    "amb_water", "amb_crickets", "amb_wind", "amb_stereo_pan",
    "vocoder_carrier", "vocoder_channel", "vocoder_ring_mod",
];

// (sample rate, rendered audio) for battery item i; every argument
// matches run_upstream.py, with upstream default arguments spelled out.
fn build_item(i: Int) -> (Int, nd.Nd) {
    if i == 0 { return (8000, synths.env_adsr(4000, 8000, 0.05, 0.1, 0.6, 0.1)); }
    if i == 1 { return (8000, synths.voice_rhodes(220.0, 0.5, 8000, 0.75)); }
    if i == 2 { return (8000, synths.voice_sub(220.0, 0.5, 8000, 0.7)); }
    if i == 3 { return (8000, synths.voice_bell(220.0, 0.5, 8000, 0.5)); }
    if i == 4 { return (8000, synths.voice_fm_lead(220.0, 0.5, 8000, 0.8)); }
    if i == 5 { return (8000, synths.voice_slap_bass(110.0, 0.5, 8000, 0.8)); }
    if i == 6 { return (8000, synths.voice_juno_pad(220.0, 0.5, 8000, 0.7, 5, 12.0)); }
    if i == 7 { return (22050, synths.voice_whistle(880.0, 0.5, 22050, 0.8)); }
    if i == 8 { return (22050, drums.voice_kick(22050, 105.0, 52.0, 0.30)); }
    if i == 9 { return (22050, drums.voice_brush_snare(22050, 0.22)); }
    if i == 10 { return (22050, drums.voice_snap(22050, 0.12)); }
    if i == 11 { return (22050, drums.voice_shaker(22050, 0.08)); }
    if i == 12 { return (22050, drums.voice_hat(22050, 0.06)); }
    if i == 13 { return (22050, drums.voice_conga(22050, 0.16, 250.0)); }
    if i == 14 { return (22050, drums.render_drums_on_beats(beats, 2.0, 22050, sections, false)); }
    if i == 15 { return (8000, dsp.rms_normalize(base_stereo_8k(), -18.0)); }
    if i == 16 { return (8000, dsp.tape_wobble(base_stereo_8k(), 8000, 0.22, 32.0, 5.0, 5.0)); }
    if i == 17 { return (8000, dsp.sidechain_pump(base_stereo_8k(), 8000, 120, 0.3)); }
    if i == 18 { return (22050, dsp.vinyl_crackle(0.5, 22050, 90.0, 0.03)); }
    if i == 19 { return (22050, dsp.cassette_hiss(0.5, 22050, 0.010)); }
    if i == 20 { return (8000, dsp.pad_to(base_stereo_8k(), 6000)); }
    if i == 21 { return (8000, dsp.mix_fades(base_stereo_8k(), 8000, 0.1, 0.2)); }
    if i == 22 { return (8000, dsp.limit_peak(base_stereo_8k().muls(5.0), 0.97)); }
    if i == 23 { return (8000, choppers.extract_hook(chop_base_8k(), 0.2, 0.7, 8000, 0.1, 0.4)); }
    if i == 24 {
        let hook = choppers.extract_hook(chop_base_8k(), 0.2, 0.7, 8000, 0.1, 0.4);
        return (8000, choppers.place_hook_loops(8000, 8000, hook,
                                                [(0.0, 3, 0.15), (0.55, 2, 0.2)], 0.75, 0.7));
    }
    if i == 25 { return (8000, ambience.render_water(0.5, 8000, 0.15, 120.0, 1500.0, 0.12)); }
    if i == 26 { return (22050, ambience.render_crickets(0.5, 22050, 4.0, 4200.0, 6200.0, 30.0, 0.75, 0.06)); }
    if i == 27 { return (8000, ambience.render_wind(0.5, 8000, 0.15, 0.04)); }
    if i == 28 { return (8000, ambience.stereo(synths.voice_bell(220.0, 0.5, 8000, 0.5), 0.3)); }
    if i == 29 { return (22050, vocoder.render_vocoder_carrier(carrier_chords_08, 0.8, 22050, 1.0, 48)); }
    if i == 30 {
        let carrier = vocoder.render_vocoder_carrier(carrier_chords_05, 0.5, 22050, 1.0, 48);
        return (22050, vocoder.channel_vocoder(mod_stereo_22k(), carrier, 22050,
                                               18, 80.0, 9000.0, 30.0, 5.0));
    }
    if i == 31 { return (22050, vocoder.ring_modulate(mod_stereo_22k(), 22050, 82.0, 0.25)); }
    panic("battery: no item {i}")
}

// ---- chords.txt (replicates run_upstream.py's text format exactly) ------

fn py_int_list(xs: List[Int]) -> String {
    "[" + xs.map(|v| "{v}").join(", ") + "]"
}

fn chord_lines(name: String) -> List[String] {
    let lines = [];
    let parse_repr = match synths.parse_chord(name) {
        Some((r, kind)) -> "({r}, '{kind}')",
        None -> "(None, None)",
    };
    let root_repr = match synths.chord_root_midi(name, 33) {
        Some(v) -> "{v}",
        None -> "None",
    };
    let voicing = synths.chord_voicing_midi(name, 60);
    let pad = synths.chord_pad_voicing_midi(name, 48, true);
    let hz = voicing.map(|m| "{synths.midi_to_hz(m, 1.0)}");
    let hz_slow = voicing.map(|m| "{synths.midi_to_hz(m, 0.9)}");
    lines.push("name={name} parse={parse_repr} root={root_repr} "
        + "voicing={py_int_list(voicing)} pad={py_int_list(pad)}");
    lines.push("  hz=[" + hz.join(", ") + "]");
    lines.push("  hz_slow090=[" + hz_slow.join(", ") + "]");
    lines
}

fn write_chords(outdir: String) {
    let chords = ["C", "Am", "F", "G7", "Cmaj7", "Am7", "Dm7", "F#m7", "Bb",
                  "Ebmaj7", "Db7", "G#m", "Xyz"];
    let lines = [];
    for name in chords {
        for line in chord_lines(name) { lines.push(line); }
    }
    // upstream's final chord is Python None: parse/root are None, the
    // voicings are empty — same output shape as an unparseable name
    lines.push("name=None parse=(None, None) root=None voicing=[] pad=[]");
    lines.push("  hz=[]");
    lines.push("  hz_slow090=[]");
    fs.write("{outdir}/chords.txt", lines.join("\n") + "\n").unwrap();
    println("chords.txt: {chords.len() + 1} chords");
}

// ---- main ----------------------------------------------------------------

let args = os.args();
if args.len() < 1 || args.len() > 2 {
    println("usage: socrates ports/claudewave/battery.soc OUTDIR [ITEM]");
    os.exit(64);
}
let outdir = args[0];
let only = if args.len() == 2 { args[1] } else { "" };
fs.create_dir(outdir).unwrap();

let stream_path = match os.env("CLAUDEWAVE_STREAM") {
    Some(p) -> p,
    None -> {
        println("battery: set CLAUDEWAVE_STREAM to the rand_stream.txt path "
            + "(generate it with ports/claudewave/reference/gen_stream.py)");
        os.exit(64)
    }
};
let st = match rand.load(stream_path) {
    Ok(s) -> s,
    Err(e) -> {
        println("battery: cannot load stream: {e}");
        os.exit(66)
    }
};
synths.set_stream(st);
drums.set_stream(st);
dsp.set_stream(st);
ambience.set_stream(st);
vocoder.set_stream(st);

println("battery: {names.len()} items, stream stride {item_stride}");
let manifest = [];
for (idx, name) in names.enumerate() {
    if only != "" && only != name { continue; }
    let offset = idx * item_stride;
    st.seek(offset);
    let (sr, arr) = build_item(idx);
    let draws = st.cursor - offset;
    if draws >= item_stride {
        panic("{name} consumed {draws} draws (>= stride {item_stride})");
    }
    audio.write_paw(arr, sr, "{outdir}/{name}.paw").unwrap();
    let line = "{str(idx).pad_left(2, "0")} {name} offset={offset} sr={sr} "
        + "frames={arr.frames()} ch={arr.ch} draws={draws}";
    manifest.push(line);
    println(line);
}
write_chords(outdir);
fs.write("{outdir}/manifest.txt", manifest.join("\n") + "\n").unwrap();
println("done: {outdir}");
