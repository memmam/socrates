// Bench: std.lists reductions on 300k ints — 10 sum passes plus one
// min/max pass and one callback-comparator min_by pass.
import std.lists;

let mut xs = [];
for i in 0..300000 {
    xs.push(i * 7 % 1000003);
}
let mut total = 0;
for _ in 0..10 {
    total = (total + lists.sum(xs)) % 1000003;
}
let lo = lists.min(xs).unwrap();
let hi = lists.max(xs).unwrap();
let first_even = lists.min_by(xs, |a, b| (a % 2) - (b % 2)).unwrap();
println("{total} {lo} {hi} {first_even}");
