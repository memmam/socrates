// Bench: List primitives — 300k pushes into a growing list, one
// callback map/filter/fold chain over it, and 300k raw Int index reads.
let mut xs = [];
for i in 0..300000 {
    xs.push(i);
}
let ys = xs.map(|x| x * 2 + 1);
let zs = ys.filter(|x| x % 3 != 0);
let total = zs.fold(0, |a, x| (a + x) % 1000003);
let mut idx_sum = 0;
for j in 0..300000 {
    idx_sum = (idx_sum + xs[j]) % 1000003;
}
println("{total} {idx_sum}");
