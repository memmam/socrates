// Bench: container display — 600 str() renders each of a 4000-string
// list (half needing quote/newline escapes, half plain) and a 2000-int
// list; exercises display_inner's quoting and number-formatting paths.
let mut words = [];
let mut nums = [];
for i in 0..2000 {
    words.push("w{i} plain");
    words.push("q{i} \"quoted\"\nline");
    nums.push(i * 7919 % 1000000);
}
let mut total = 0;
for _ in 0..600 {
    total += str(words).len() + str(nums).len();
}
println(total);
