// Bench: the fused range-literal counted loop — `for i in 0..N` compiles
// to ForNextRange stepping two Int stack slots (no ForPrep, no heap
// Range): the modern counted-loop idiom's dispatch floor, minimal body.
// bench/arith_loop.soc is the deliberate while-loop counterpart (same
// body; iteration counts differ, so compare loop shapes via per-iteration
// cost, not raw seconds).
let mut acc = 0;
for i in 0..4000000 {
    acc = (acc + i * 3) % 1000003;
}
println(acc);
