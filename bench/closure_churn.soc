// Bench: closure allocation churn — 400k rounds each allocating a
// one-upvalue closure, calling it once, and dropping it (Closure alloc +
// upvalue capture + closure call; the v0.4 GC pacing benchmark's shape).
fn make_adder(n: Int) -> fn(Int) -> Int {
    |x| x + n
}
let mut acc = 0;
for i in 0..400000 {
    let f = make_adder(i % 97);
    acc = (acc + f(i)) % 1000003;
}
println(acc);
