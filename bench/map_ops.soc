// Bench: map insert/get with interpolated string keys (structural
// hashing) — 120k inserts over 40k distinct keys, then 120k gets of
// which one fifth miss.
let m = {:};
for i in 0..120000 {
    m.insert("key_{i % 40000}", i);
}
let mut hits = 0;
for j in 0..120000 {
    match m.get("key_{j % 50000}") {
        Some(_) -> { hits += 1; }
        None -> {}
    }
}
println("{m.len()} {hits}");
