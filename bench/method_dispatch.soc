// Bench: user impl-method dispatch — 1M bound-method lookups + calls on
// one struct receiver, each call reading and writing a field.
struct Counter { n: Int }
impl Counter {
    pub fn bump(self, k: Int) -> Int {
        self.n = self.n + k;
        self.n
    }
}
let c = Counter { n: 0 };
let mut acc = 0;
for i in 0..1000000 {
    acc = (acc + c.bump(i % 13)) % 1000003;
}
println("{acc} {c.n}");
